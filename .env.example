# API key de Anthropic para extracción OCR de facturas con Claude
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Token de ESIOS (Red Eléctrica de España) para consultar precios PVPC
# Solicitar en: https://api.esios.ree.es
ESIOS_API_KEY=

# Supabase — analytics anónimos (servidor). Usa la clave secreta, NO la pública.
# En Supabase: Project Settings → API / API Keys
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — rate limiting de /api/analizar (límite por IP + tope diario)
# Crear base de datos en: https://console.upstash.com
# Si se dejan vacías, el rate limiting se desactiva (degradación segura).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
